{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A songwriting project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "lastModified": { "type": "number" },
        "lyrics": { "type": "string" },
        "suggestion": { "type": "string" },
        "feedback": { "type": "string" },
        "companion": { "type": "object" },
        "messages": { "type": "array" },
        "activeTab": { "type": "string" },
        "audioClips": { "type": "array" },
        "uid": { "type": "string" }
      },
      "required": ["title", "lastModified", "uid"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "subscription": { "type": "string", "enum": ["free", "pro", "elite"] },
        "creditsRemaining": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "guest", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "username", "subscription", "creditsRemaining"]
    },
    "ProjectVersion": {
      "title": "ProjectVersion",
      "description": "A snapshot of a project",
      "type": "object",
      "properties": {
        "timestamp": { "type": "number" },
        "lyrics": { "type": "string" },
        "suggestion": { "type": "string" },
        "feedback": { "type": "string" },
        "audioClips": { "type": "array" }
      },
      "required": ["timestamp", "lyrics"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "User's songwriting projects"
    },
    "/users/{userId}/projects/{projectId}/versions/{versionId}": {
      "schema": "ProjectVersion",
      "description": "Project version snapshots"
    }
  }
}
